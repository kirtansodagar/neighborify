# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# Database
# MongoDB Atlas connection string for the Neighborify database.
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/neighborify

# Auth
# Strong secret for signing short-lived access tokens.
JWT_SECRET=replace-with-access-token-secret
JWT_EXPIRES_IN=15m
# Strong secret for signing refresh tokens.
JWT_REFRESH_SECRET=replace-with-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=30d

# Cloudinary
# Cloudinary account credentials for media uploads.
CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret

# Twilio
# Twilio credentials for sending SMS OTPs.
TWILIO_ACCOUNT_SID=replace-with-account-sid
TWILIO_AUTH_TOKEN=replace-with-auth-token
TWILIO_PHONE_NUMBER=replace-with-twilio-phone-number

# Firebase
# Firebase service account credentials for push notifications.
FIREBASE_PROJECT_ID=replace-with-project-id
FIREBASE_PRIVATE_KEY=replace-with-private-key
FIREBASE_CLIENT_EMAIL=replace-with-client-email

# Google Maps
# Google Maps API key for geocoding pincodes.
GOOGLE_MAPS_API_KEY=replace-with-google-maps-api-key

# Razorpay
# Razorpay credentials for payments and webhook verification.
RAZORPAY_KEY_ID=replace-with-key-id
RAZORPAY_KEY_SECRET=replace-with-key-secret
RAZORPAY_WEBHOOK_SECRET=replace-with-webhook-secret

# Admin
# Seeded admin login details.
ADMIN_EMAIL=admin@neighborify.in
ADMIN_PASSWORD=replace-with-admin-password
